{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    
    // ✅ REMOVA "types" OU use apenas em testes via tsconfig.test.json
    // "types": ["jest", "node"], 
    
    // ✅ Opcional: especificar onde buscar definições de tipo
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  
  // ✅ Inclui tudo em src/ (inclusive src/types/*.d.ts)
  "include": ["src/**/*"],
  
  "exclude": ["node_modules", "dist", "src/__tests__"]
}