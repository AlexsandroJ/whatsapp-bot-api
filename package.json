  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:memory": "cross-env NODE_ENV=development USE_IN_MEMORY_DB=true ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:local": "cross-env NODE_ENV=development USE_IN_MEMORY_DB=false ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "test": "cross-env NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit",
    "build": "tsc"
  },
